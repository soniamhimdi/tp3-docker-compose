# Variables d'environnement nécessaires
# Copiez ce fichier en .env et remplissez les valeurs

# ─────────────────────────────────────
# API Node.js
# ─────────────────────────────────────

# Port sur lequel l'API écoute
PORT=5000

# URL de connexion à MongoDB
# "database" = nom du service dans docker-compose.yml
MONGO_URL=mongodb://database:27017/tp3

# Environnement : development ou production
NODE_ENV=development

# ─────────────────────────────────────
# Client React (Vite)
# ─────────────────────────────────────

# URL de l'API appelée par le navigateur
# En dev : localhost car le navigateur ne connaît pas "api"
# En prod : laisser vide ou mettre /api (nginx redirige)
VITE_API_URL=http://localhost:5000/api